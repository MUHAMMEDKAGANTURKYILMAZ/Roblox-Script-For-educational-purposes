-- DRAGGING
-- ====================================================================
local dragging = false
local dragInput, dragStart, startPos

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        local screenSize = camera.ViewportSize
        local targetX = startPos.X.Offset + delta.X
        local targetY = startPos.Y.Offset + delta.Y
        local clampedX = math.clamp(startPos.X.Scale * screenSize.X + targetX, 0, screenSize.X - MainFrame.AbsoluteSize.X)
        local clampedY = math.clamp(startPos.Y.Scale * screenSize.Y + targetY, 0, screenSize.Y - MainFrame.AbsoluteSize.Y)
        MainFrame.Position = UDim2.new(0, clampedX, 0, clampedY)
    end
end)
