-- HEARTBEAT
-- ====================================================================
RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not (humanoid and hrp and humanoid.Health > 0) then return end

    local currentTime = os.clock()
    local isFlying = flyActive or vehicleFlyActive or swimFlyActive or sitFlyActive

    if currentTime - lastGlobalForceUpdate >= 5 then
        lastGlobalForceUpdate = currentTime
        if not isFlying then humanoid.WalkSpeed = walkSpeed end
        if humanoid.UseJumpPower then
            humanoid.JumpPower = jumpPower
        else
            humanoid.JumpHeight = jumpPower / 3.5
        end
    end

    if not isFlying and humanoid.WalkSpeed ~= walkSpeed then
        humanoid.WalkSpeed = walkSpeed
    end

    if noclipActive then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end

    if flingActive then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
        hrp.AssemblyAngularVelocity = Vector3.new(0, 9999, 0)
        if humanoid.MoveDirection.Magnitude > 0 then
            hrp.AssemblyLinearVelocity = humanoid.MoveDirection * 100
        else
            hrp.AssemblyLinearVelocity = Vector3.zero
        end
    end

    if spinSpeed > 0 and not flingActive then
        if not hrp:FindFirstChild("KatroSpinner") then
            local bAV = Instance.new("BodyAngularVelocity")
            bAV.Name = "KatroSpinner"
            bAV.MaxTorque = Vector3.new(0, 1e9, 0)
            bAV.Parent = hrp
        end
        hrp.KatroSpinner.AngularVelocity = Vector3.new(0, spinSpeed, 0)
    else
        local s = hrp:FindFirstChild("KatroSpinner")
        if s then s:Destroy() end
    end

    if antiVoidActive then
        if hrp.Position.Y < -30 or (hrp.AssemblyLinearVelocity.Y < -80 and hrp.Position.Y < 10) then
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.CFrame = CFrame.new(hrp.Position.X, 60, hrp.Position.Z)
        end
    end

    if swimFlyActive then
        if humanoid:GetState() ~= Enum.HumanoidStateType.Swimming then
            humanoid:ChangeState(Enum.HumanoidStateType.Swimming)
        end
    end

    if sitFlyActive then
        humanoid.PlatformStand = true
        humanoid:ChangeState(Enum.HumanoidStateType.PlatformStanding)
    end

    if isFlying and flyBV and flyBG then
        local flyTarget = hrp
        if vehicleFlyActive and humanoid.SeatPart then
            flyTarget = humanoid.SeatPart
        end
        if flyTarget then
            flyBG.CFrame = camera.CFrame
            local moveDir = humanoid.MoveDirection
            if moveDir.Magnitude > 0 then
                local camLook = camera.CFrame.LookVector
                local forwardFactor = moveDir:Dot(Vector3.new(camLook.X, 0, camLook.Z).Unit)
                local resultVel = Vector3.new(moveDir.X, camLook.Y * forwardFactor, moveDir.Z).Unit * flySpeed
                flyBV.Velocity = resultVel
            else
                flyBV.Velocity = Vector3.zero
            end
        end
    end
end)

