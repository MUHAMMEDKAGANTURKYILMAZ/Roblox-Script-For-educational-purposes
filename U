_G.KatroToken = {
    Key = 13503,
    Time = os.time()
}

local EXPECTED_HASH = 13503

if _G.KatroToken == nil or type(_G.KatroToken) ~= "table" then
    game.Players.LocalPlayer:Kick("Security Breach: Missing Panel Handshake [Error 0x1]")
    return
end

local serverKey = _G.KatroToken.Key or 0
local timestamp = _G.KatroToken.Time or 0
local osTime = os.time()

if (serverKey ~= EXPECTED_HASH) or (osTime - timestamp > 10) then
    game.Players.LocalPlayer:Kick("Security Breach: Token Invalid or Expired [Error 0x2]")
    return
end

