local function clearAllFlyStates()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if hrp then stop360Fly(hrp) end
    if humanoid and humanoid.SeatPart then stop360Fly(humanoid.SeatPart) end
    if humanoid then humanoid.PlatformStand = false end

    flyActive = false; vehicleFlyActive = false
    swimFlyActive = false; sitFlyActive = false

    if fBtn then fBtn.Text = "360 Fly"; fBtn.TextColor3 = Color3.fromRGB(255, 255, 255) end
    if vfBtn then vfBtn.Text = "V. Fly"; vfBtn.TextColor3 = Color3.fromRGB(255, 255, 255) end
    if sfBtn then sfBtn.Text = "Swim Fly"; sfBtn.TextColor3 = Color3.fromRGB(255, 255, 255) end
    if sitfBtn then sitfBtn.Text = "Sit Fly"; sitfBtn.TextColor3 = Color3.fromRGB(255, 255, 255) end
end

local function activateFly()
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if not flyActive then
        clearAllFlyStates()
        flyActive = true
        start360Fly(hrp)
        if fBtn then fBtn.Text = "Fly: ON"; fBtn.TextColor3 = Color3.fromRGB(0, 255, 150) end
    end
end

